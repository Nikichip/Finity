# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# PostgreSQL connection string from Render
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://your_user:your_password@your_host:5432/your_dbname

# JWT secret — use a long random string in production
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-to-a-long-random-secret-string

# Frontend URL for CORS (your Render frontend URL or * for development)
FRONTEND_URL=*
